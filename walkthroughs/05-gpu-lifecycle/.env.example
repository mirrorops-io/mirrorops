# GPU Lifecycle — required n8n environment variables
# Set these in n8n (Settings → Variables) or the container environment.

# Hetzner Cloud API token with read+write on the project holding the GPU box
HETZNER_API_TOKEN=

# Numeric server id of the GPU instance (Hetzner console → server → id)
HETZNER_GPU_SERVER_ID=

# Ollama base URL on your private network (used as the readiness probe)
OLLAMA_URL=http://10.0.0.5:11434

# Cold-boot hard timeout in seconds (includes model load). Default 180.
GPU_BOOT_TIMEOUT_SEC=180

# Minutes of idle before the shutdown-check powers the box off. Default 15.
GPU_IDLE_MINUTES=15
